<svg xmlns="http://www.w3.org/2000/svg" width="900" height="500" viewBox="0 0 900 500">
  <defs>
    <linearGradient id="bg" x1="0%" y1="0%" x2="100%" y2="100%">
      <stop offset="0%" style="stop-color:#f8f9fa;stop-opacity:1" />
      <stop offset="100%" style="stop-color:#e9ecef;stop-opacity:1" />
    </linearGradient>
  </defs>
  <rect width="900" height="500" fill="url(#bg)" rx="8"/>
  <!-- Chart lines -->
  <polyline points="50,400 150,350 250,380 350,300 450,250 550,280 650,200 750,150 850,180" fill="none" stroke="#387ed1" stroke-width="3"/>
  <polyline points="50,420 150,380 250,400 350,350 450,320 550,340 650,280 750,220 850,250" fill="none" stroke="#e95325" stroke-width="2" stroke-dasharray="5,5"/>
  <!-- Bars -->
  <rect x="80" y="350" width="30" height="100" fill="#387ed1" opacity="0.3" rx="2"/>
  <rect x="180" y="300" width="30" height="150" fill="#4caf50" opacity="0.3" rx="2"/>
  <rect x="280" y="320" width="30" height="130" fill="#387ed1" opacity="0.3" rx="2"/>
  <rect x="380" y="250" width="30" height="200" fill="#4caf50" opacity="0.3" rx="2"/>
  <rect x="480" y="280" width="30" height="170" fill="#387ed1" opacity="0.3" rx="2"/>
  <rect x="580" y="220" width="30" height="230" fill="#4caf50" opacity="0.3" rx="2"/>
  <rect x="680" y="200" width="30" height="250" fill="#387ed1" opacity="0.3" rx="2"/>
  <rect x="780" y="180" width="30" height="270" fill="#4caf50" opacity="0.3" rx="2"/>
  <!-- Title -->
  <text x="450" y="80" font-family="Arial, sans-serif" font-size="28" fill="#333" text-anchor="middle" font-weight="300">Trading Dashboard</text>
  <text x="450" y="110" font-family="Arial, sans-serif" font-size="14" fill="#999" text-anchor="middle">Invest in stocks, derivatives, mutual funds & more</text>
</svg>
