<svg xmlns="http://www.w3.org/2000/svg" width="500" height="350" viewBox="0 0 500 350">
  <rect width="500" height="350" fill="#f0f4f8" rx="8"/>
  <rect x="30" y="30" width="440" height="290" fill="white" rx="6" stroke="#ddd" stroke-width="1"/>
  <rect x="30" y="30" width="440" height="30" fill="#f5f5f5" rx="6"/>
  <circle cx="50" cy="45" r="5" fill="#ff5f56"/>
  <circle cx="68" cy="45" r="5" fill="#ffbd2e"/>
  <circle cx="86" cy="45" r="5" fill="#27c93f"/>
  <!-- Dashboard elements -->
  <rect x="60" y="80" width="180" height="80" fill="#e3f2fd" rx="4"/>
  <rect x="260" y="80" width="180" height="80" fill="#e8f5e9" rx="4"/>
  <rect x="60" y="180" width="380" height="120" fill="#f5f5f5" rx="4"/>
  <text x="250" y="110" font-family="Arial, sans-serif" font-size="18" fill="#333" text-anchor="middle" font-weight="bold">Console</text>
  <text x="250" y="130" font-family="Arial, sans-serif" font-size="11" fill="#999" text-anchor="middle">Central Dashboard</text>
</svg>
