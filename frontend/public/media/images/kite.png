<svg xmlns="http://www.w3.org/2000/svg" width="500" height="350" viewBox="0 0 500 350">
  <rect width="500" height="350" fill="#f0f4f8" rx="8"/>
  <!-- Browser mockup -->
  <rect x="30" y="30" width="440" height="290" fill="white" rx="6" stroke="#ddd" stroke-width="1"/>
  <rect x="30" y="30" width="440" height="30" fill="#f5f5f5" rx="6"/>
  <circle cx="50" cy="45" r="5" fill="#ff5f56"/>
  <circle cx="68" cy="45" r="5" fill="#ffbd2e"/>
  <circle cx="86" cy="45" r="5" fill="#27c93f"/>
  <!-- Chart area -->
  <polyline points="60,250 120,220 180,240 240,180 300,200 360,150 420,170" fill="none" stroke="#387ed1" stroke-width="2"/>
  <text x="250" y="100" font-family="Arial, sans-serif" font-size="18" fill="#333" text-anchor="middle" font-weight="bold">Kite</text>
  <text x="250" y="120" font-family="Arial, sans-serif" font-size="11" fill="#999" text-anchor="middle">Trading Platform</text>
</svg>
